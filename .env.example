# ─── API Keys ────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here    # gsk_... key from console.groq.com
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://careai:careai_secret@postgres:5432/careai
DATABASE_URL_SYNC=postgresql://careai:careai_secret@postgres:5432/careai
POSTGRES_USER=careai
POSTGRES_PASSWORD=careai_secret
POSTGRES_DB=careai

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_TTL=1800

# ─── Server ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_EXTERNAL_URL=https://your-ngrok-url.ngrok-free.app  # Required for Twilio outbound callbacks
DEBUG=false
LOG_LEVEL=warning

# ─── Security ─────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://your-app.example.com
# Strong random secret for JWT signing (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-openssl-rand-hex-32-output
JWT_EXPIRY_MINUTES=60

# ─── TTS Config ──────────────────────────────────────────
ELEVENLABS_VOICE_EN=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_HI=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_TA=21m00Tcm4TlvDq8ikWAM

# --- Twilio (Outbound Dialer) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── LLM Config ──────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ─── Next.js Frontend ────────────────────────────────────
# URL of the FastAPI backend (used by Next.js API routes to proxy requests)
BACKEND_URL=http://localhost:8000
# Alias for Groq key used by Next.js AI SDK routes
GROQ_API_KEY=your_groq_api_key_here
